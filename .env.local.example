# ---- Supabase (públicas, embutidas no bundle) ----
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-chave-publicavel

# Opcional para projetos antigos que ainda usam anon key:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima

# URL pública do site (em dev pode ser http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Servidor (NUNCA prefixar com NEXT_PUBLIC_) ----
# Service role do Supabase (Settings -> API -> service_role). Só no servidor!
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-aqui

# Mercado Pago — em dev use as credenciais de TESTE (sandbox).
MERCADO_PAGO_ACCESS_TOKEN=cole-o-access-token-de-teste-aqui
MERCADO_PAGO_WEBHOOK_SECRET=cole-o-webhook-secret-aqui

# ---- IA para correção de redação (server-only) ----
ESSAY_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=cole-a-chave-anthropic-aqui
# OPENAI_API_KEY=cole-a-chave-openai-aqui
# ESSAY_AI_MODEL=
