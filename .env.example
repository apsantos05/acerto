# ---- Supabase (públicas, embutidas no bundle) ----
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-chave-publicavel

# Opcional para projetos antigos que ainda usam anon key:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima

# URL pública do site (usada nos redirects do checkout e no webhook).
NEXT_PUBLIC_SITE_URL=https://acertavest.com.br

# ---- Servidor (NUNCA prefixar com NEXT_PUBLIC_) ----
# Service role do Supabase — usada só no webhook para atualizar profiles.plan.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-aqui

# Mercado Pago (Assinaturas / Checkout). Access token de PRODUÇÃO ou de TESTE.
MERCADO_PAGO_ACCESS_TOKEN=cole-o-access-token-aqui
# Secret do webhook (painel do Mercado Pago -> Webhooks) para validar a assinatura.
MERCADO_PAGO_WEBHOOK_SECRET=cole-o-webhook-secret-aqui
