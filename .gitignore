# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# importação do telegram (PDFs baixados, manifestos e config com origens)
/content/telegram/
/scripts/telegram/sources.json

# importação local (PDFs, manifesto e caches)
/content/import-local/

# cache de curadoria admin (texto extraído / OCR)
/content/admin/

# typescript
*.tsbuildinfo
next-env.d.ts
